# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
MASTER_KEY=change_me_to_a_strong_random_secret_32chars

# ── Optional ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
TRUST_PROXY=true
DB_SSL=true
DB_POOL_MAX=5

# ── Security ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=
IP_WHITELIST=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
MESSAGE_COOLDOWN_MS=5000

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=2000

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WA_SESSION_NAME=advaylink
WA_RECONNECT_DELAY_MS=5000
